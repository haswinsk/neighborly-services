{
  "buildCommand": "npm run build",
  "installCommand": "npm install:all",
  "outputDirectory": "frontend/dist",
  "env": {
    "DATABASE_URL": "@DATABASE_URL",
    "JWT_SECRET": "@JWT_SECRET",
    "CLIENT_URL": "@CLIENT_URL",
    "VITE_API_URL": "@VITE_API_URL"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
