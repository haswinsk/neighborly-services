# Database Configuration (AWS Aurora PostgreSQL)
DATABASE_URL="postgresql://user:password@hostname:5432/neighborly_services"

# Server Configuration
NODE_ENV="development"
PORT=8081

# Authentication
JWT_SECRET="your-secret-key-min-32-chars-required-in-production"

# Frontend URL
CLIENT_URL="http://localhost:5173"

# Business Configuration
ADMIN_COMMISSION_RATE=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
