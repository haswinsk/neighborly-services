// Prisma schema for Neighborly Services
// Database: PostgreSQL (AWS Aurora)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model for authentication and profile management
model User {
  id        String   @id @unique
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  location  String?  @db.Text
  latitude  Float?
  longitude Float?
  
  role      Role     @default(CUSTOMER)
  approved  Boolean  @default(false)
  
  // Relations
  services    Service[]
  bookings    Booking[]
  reviews     Review[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

// Service model for service listings
model Service {
  id        String   @id @unique
  
  serviceName   String   @db.VarChar(255)
  description   String   @db.Text
  category      String   @db.VarChar(100)
  price         Float
  
  // Provider information
  providerId    String
  provider      User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  providerName      String   @db.VarChar(255)
  providerLocation  String?  @db.Text
  providerLatitude  Float?
  providerLongitude Float?
  
  // Service metrics
  rating      Float   @default(0)
  reviewCount Int     @default(0)
  availability String? @db.VarChar(255)
  
  // Relations
  bookings    Booking[]
  reviews     Review[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([category])
}

// Booking model for service bookings
model Booking {
  id        String   @id @unique
  
  customerId    String
  customer      User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerName  String   @db.VarChar(255)
  
  providerId    String
  provider      User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceName   String   @db.VarChar(255)
  
  bookingDate   DateTime
  status        BookingStatus @default(Pending)
  price         Float
  description   String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([providerId])
  @@index([serviceId])
  @@index([status])
}

enum BookingStatus {
  Pending
  Accepted
  InProgress
  Completed
  Cancelled
}

// Review model for service reviews and ratings
model Review {
  id        String   @id @unique
  
  customerId    String
  customer      User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  rating    Int      @db.SmallInt
  comment   String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([customerId])
  @@unique([serviceId, customerId])
}
